@using GymMangmentSystem.BLL.ViewModels.PlanViewModels
@model UpdatePlanViewModel

@{
    ViewData["Title"] = "Edit Plan";
}

<div class="container mt-5">

    ```
    <div class="mb-4">
        <h2 class="text-primary-color">Edit Plan</h2>
        <p class="text-muted">Update plan details</p>
    </div>

    <form method="post">

        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="row">

            <div class="col-12 mb-3">
                <label asp-for="PlanName" class="form-label fw-semibold">
                    Plan Name <span class="text-danger">*</span>
                </label>

                <input asp-for="PlanName"
                       class="form-control" />

                <span asp-validation-for="PlanName"
                      class="text-danger"></span>
            </div>

            <div class="col-md-6 mb-3">

                <label asp-for="DurationDays"
                       class="form-label fw-semibold">
                    Duration (Days) <span class="text-danger">*</span>
                </label>

                <input asp-for="DurationDays"
                       type="number"
                       class="form-control" />

                <small class="text-muted">
                    e.g., 30 days = 1 month
                </small>

                <span asp-validation-for="DurationDays"
                      class="text-danger d-block"></span>

            </div>

            <div class="col-md-6 mb-3">

                <label asp-for="Price"
                       class="form-label fw-semibold">
                    Price (EGP) <span class="text-danger">*</span>
                </label>

                <input asp-for="Price"
                       type="number"
                       step="0.01"
                       class="form-control" />

                <span asp-validation-for="Price"
                      class="text-danger"></span>

            </div>

            <div class="col-12 mb-3">

                <label asp-for="Description"
                       class="form-label fw-semibold">
                    Description <span class="text-danger">*</span>
                </label>

                <textarea asp-for="Description"
                          class="form-control"
                          rows="5"></textarea>

                <span asp-validation-for="Description"
                      class="text-danger"></span>

            </div>

        </div>

        <hr />

        <div class="d-flex justify-content-between">

            <a asp-action="Index"
               class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i>
                Cancel
            </a>

            <button type="submit"
                    class="btn btn-primary">
                <i class="bi bi-check-lg"></i>
                Update Plan
            </button>

        </div>

    </form>
    ```

</div>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}
